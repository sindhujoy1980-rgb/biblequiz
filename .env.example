# ============================================================
# CyFam Bible Quiz Backend — Environment Variables
# Copy this file to .env and fill in all values
# NEVER commit .env to GitHub!
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── WhatsApp / Meta ───────────────────────────────────────────
WHATSAPP_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxx
WHATSAPP_PHONE_NUMBER_ID=1234567890123456
WHATSAPP_FLOW_ID=1234567890123456

# ── WhatsApp Flow RSA Private Key ─────────────────────────────
# Generate with: openssl genrsa -out private.pem 2048
# Then paste the full content below (keep the newlines as \n)
WHATSAPP_FLOW_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----"

# ── Security ──────────────────────────────────────────────────
# Used to sign/verify flow_tokens (any long random string)
JWT_SECRET=your_super_long_random_secret_key_here_min_32_chars

# Used to protect cron endpoints from unauthorized calls
CRON_SECRET=another_random_secret_for_cron_jobs

# ── Google Gemini AI ─────────────────────────────────────────
GEMINI_API_KEY=AIzaSy...
GEMINI_MODEL=gemini-1.5-flash
GEMINI_MAX_RETRIES=3
