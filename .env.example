# ============================================================
# CyFam Bible Quiz Backend — Environment Variables
# Copy this file to .env and fill in all values
# NEVER commit .env to GitHub!
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── WhatsApp / Meta ───────────────────────────────────────────
WHATSAPP_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxx
WHATSAPP_PHONE_NUMBER_ID=1234567890123456
WHATSAPP_BUSINESS_ACCOUNT_ID=987654321098765
WHATSAPP_FLOW_ID=1234567890123456

# ── WhatsApp Webhook ──────────────────────────────────────────
# Set in Meta App Dashboard → WhatsApp → Configuration → Webhook
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_custom_verify_token_string
# App Secret from Meta App Dashboard → Settings → Basic → App Secret
WHATSAPP_APP_SECRET=abcdef1234567890abcdef1234567890

# ── WhatsApp Flow RSA Private Key ─────────────────────────────
# Generate: openssl genrsa -out private.pem 2048
# Upload public.pem to Meta → Phone Number → Encryption tab
# Paste full content of private.pem here (keep newlines as \n)
WHATSAPP_FLOW_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----"

# ── Security ──────────────────────────────────────────────────
# Used to sign/verify flow_tokens (min 32 random chars)
JWT_SECRET=your_super_long_random_secret_key_here_min_32_chars
# Used to protect cron endpoints from unauthorized calls
CRON_SECRET=another_random_secret_for_cron_jobs

# ── CORS ─────────────────────────────────────────────────────
# URL of the admin dashboard (used for CORS whitelist)
ADMIN_DASHBOARD_URL=https://bqa-admin.vercel.app

# ── Google Gemini AI ─────────────────────────────────────────
GEMINI_API_KEY=AIzaSy...
GEMINI_MODEL=gemini-1.5-flash
GEMINI_MAX_RETRIES=3

# ── App ───────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

